# Application Environment (local, production)
APP_ENV=local

# DuckDB Configuration
# Use ':memory:' for transient sessions or a file path for persistence
DUCKDB_PATH=:memory:

# Artifacts Directory
ARTIFACTS_DIR=artifacts/runs

# LLM API Keys
GOOGLE_API_KEY=your_api_key_here

# Google Cloud Configuration (for Cloud Run/Storage if needed)
GOOGLE_CLOUD_PROJECT=shyamportfolio-3f1a3
GOOGLE_CLOUD_REGION=us-central1
